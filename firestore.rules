rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Profiles ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'email', 'currency', 'subscription']) &&
               data.uid == request.auth.uid &&
               data.email is string && data.email.size() <= 256 &&
               data.currency in ['USD', 'EUR', 'GBP', 'INR'] &&
               data.subscription in ['free', 'premium'];
      }

      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        // Only allow updating certain fields (e.g. currency) if not admin
        incoming().diff(existing()).affectedKeys().hasOnly(['currency', 'displayName', 'photoURL', 'subscription'])
      );
    }

    // --- Transactions ---
    match /transactions/{transactionId} {
      function isValidTransaction(data) {
        return data.keys().hasAll(['userId', 'amount', 'category', 'date', 'type', 'paymentMethod']) &&
               data.userId == request.auth.uid &&
               data.amount is number &&
               data.category is string && data.category.size() <= 50 &&
               data.type in ['income', 'expense'] &&
               data.paymentMethod is string && data.paymentMethod.size() <= 50;
      }

      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && isValidTransaction(incoming());
      
      allow update: if isSignedIn() && 
                    existing().userId == request.auth.uid && 
                    isValidTransaction(incoming()) &&
                    incoming().userId == existing().userId; // Immutable owner

      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }
  }
}
