{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user settings, preferences, and subscription status.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "currency": { "type": "string", "enum": ["USD", "EUR", "GBP", "INR"] },
        "subscription": { "type": "string", "enum": ["free", "premium"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "currency", "subscription"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Represents an income or expense record.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "category": { "type": "string" },
        "paymentMethod": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "note": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "category", "date", "type"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Primary user profile document"
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Global transactions collection, filtered by userId"
    }
  }
}
